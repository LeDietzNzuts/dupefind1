{
  "schemaVersion": 1,
  "id": "forgeconfigapiport",
  "version": "21.1.6",
  "name": "Forge Config API Port",
  "description": "Provides NeoForge\u0027s \u0026 Forge\u0027s config systems to other modding ecosystems. Designed for a multi-loader architecture.",
  "authors": [
    "Fuzs"
  ],
  "contact": {
    "homepage": "https://github.com/Fuzss/forgeconfigapiport",
    "issues": "https://github.com/Fuzss/forgeconfigapiport/issues",
    "sources": "https://github.com/Fuzss/forgeconfigapiport"
  },
  "license": "MPL-2.0",
  "icon": "mod_logo.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "fuzs.forgeconfigapiport.fabric.impl.ForgeConfigAPIPortFabric"
    ],
    "client": [
      "fuzs.forgeconfigapiport.fabric.impl.client.ForgeConfigAPIPortFabricClient"
    ],
    "modmenu": [
      "fuzs.forgeconfigapiport.fabric.impl.integration.modmenu.ModMenuApiImpl"
    ]
  },
  "mixins": [
    "forgeconfigapiport.common.mixins.json",
    "forgeconfigapiport.fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": "\u003e\u003d0.16.1",
    "fabric-api": "\u003e\u003d0.102.0",
    "minecraft": "1.21.1",
    "java": "\u003e\u003d17"
  },
  "recommends": {
    "modmenu": "*"
  },
  "custom": {
    "modmenu": {
      "badges": [
        "library"
      ]
    }
  },
  "accessWidener": "forgeconfigapiport.accesswidener",
  "jars": [
    {
      "file": "META-INF/jars/core-3.8.0.jar"
    },
    {
      "file": "META-INF/jars/toml-3.8.0.jar"
    }
  ]
}