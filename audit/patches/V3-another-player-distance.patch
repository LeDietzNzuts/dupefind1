       if (!Boolean.FALSE.equals(Config.SERVER.allowOpeningOtherPlayerBackpacks.get())) {
          if (player.method_37908().method_8469(payload.anotherPlayerId) instanceof class_1657 anotherPlayer) {
+            // FIX V3: cap open-distance. Use the configured max distance (default ~6 blocks).
+            double maxDistance = Config.SERVER.anotherPlayerBackpackOpenMaxDistance != null
+                    ? Config.SERVER.anotherPlayerBackpackOpenMaxDistance.get()
+                    : 6.0D;
+            if (player.method_37908() != anotherPlayer.method_37908()) {
